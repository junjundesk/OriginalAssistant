<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="2dp" />
            <gradient
                android:angle="270"
                android:centerColor="#E7D1B2"
                android:endColor="#F0DFC6"
                android:startColor="#D2B99B" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="2dp" />
                <gradient
                    android:centerColor="#C96B43"
                    android:endColor="#B85C38"
                    android:startColor="#E5A36B" />

            </shape>
        </clip>
    </item>
</layer-list>
